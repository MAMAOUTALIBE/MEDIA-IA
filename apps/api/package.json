{
  "name": "@cmr/api",
  "version": "0.1.0",
  "private": true,
  "description": "CMR — API NestJS (REST + WebSocket)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src"
  },
  "dependencies": {
