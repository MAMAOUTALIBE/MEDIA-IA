    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^9",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^2.1.0"
