# ============================================================================
# MEDIA-IA · CMR — Variables d'environnement (ADR-006)
# Copier vers .env (jamais commit) puis remplir les valeurs.
# Génération des secrets : openssl rand -base64 64
# ============================================================================

# --- Base de données --------------------------------------------------------
DATABASE_URL="postgresql://cmr:CHANGE_ME@localhost:5435/cmr_dev?schema=public"
TEST_DATABASE_URL="postgresql://cmr:CHANGE_ME@localhost:5435/cmr_test?schema=public"

# --- API (apps/api) ---------------------------------------------------------
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# JWT — clé HS512, minimum 64 caractères en production
JWT_SECRET="CHANGE_ME__min_64_chars__use_openssl_rand_base64_64__CHANGE_ME"
JWT_EXPIRES_IN_SECONDS=28800

# Seed
SEED_PASSWORD="cmr2025!Dev"

# --- Web (apps/web/.env.local) ---------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:4000/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

